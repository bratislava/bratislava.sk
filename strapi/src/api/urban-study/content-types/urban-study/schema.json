{
  "kind": "collectionType",
  "collectionName": "urban_studies",
  "info": {
    "singularName": "urban-study",
    "pluralName": "urban-studies",
    "displayName": "WIP Urban Studies"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "year": {
      "type": "string"
    },
    "customPublishedAt": {
      "type": "datetime"
    },
    "pictogram": {
      "type": "enumeration",
      "enum": [
        "sprava_mesta_01",
        "transparentne_mesto_01",
        "dane_01",
        "projekty_01",
        "partnerstva_01",
        "inovacie_01",
        "data_01",
        "mhd_02",
        "cyklo_02",
        "mapy_02",
        "sprava_a_udrzba_02",
        "doprava_02",
        "parkovanie_02",
        "zdielana_mobilita_02",
        "data_02",
        "zivotne_prostredie_03",
        "zelen_03",
        "vystavba_a_nehnutelnosti_03",
        "uzemny_plan_03",
        "rozvoj_mesta_03",
        "verejne_osvetlenie_03",
        "klima_03",
        "byvanie_04",
        "sluzby_04",
        "zariadenia_04",
        "pomoc_04",
        "aktivity_04",
        "skolstvo_05",
        "sport_05",
        "deti_a_mladez_05",
        "ocenovanie_05",
        "dotacie_05",
        "kalendar_06",
        "organizacie_06",
        "dedicstvo_06",
        "sluzby_06",
        "koncepcia_06",
        "komunity_06",
        "covid_06"
      ]
    },
    "urbanStudyType": {
      "type": "enumeration",
      "required": true,
      "default": "urbanStudyType.urbanistickaStudia",
      "enum": [
        "urbanStudyType.urbanistickaStudia",
        "urbanStudyType.odvetvovaStudia",
        "urbanStudyType.uzemnyGenerel",
        "urbanStudyType.uzemnyPlan",
        "urbanStudyType.uzemnyPlanZony",
        "urbanStudyType.uzemnyPlanZmenyADoplnky",
        "urbanStudyType.iny"
      ]
    },
    "orderedBy": {
      "type": "string",
      "default": "Hlavné mesto Slovenskej republiky Bratislava"
    },
    "preparedBy": {
      "type": "string",
      "default": "Hlavné mesto Slovenskej republiky Bratislava"
    },
    "body": {
      "type": "richtext"
    },
    "approvalText": {
      "type": "richtext"
    },
    "briefFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "commentsEvaluationFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "analyticalPartFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "writtenPartFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "graphicPartFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "attachmentFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "regulations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::regulation.regulation",
      "mappedBy": "urbanStudies"
    },
    "links": {
      "type": "component",
      "component": "blocks.common-link",
      "repeatable": true
    }
  }
}
