{
  "collectionName": "components_sections_faqs",
  "info": {
    "displayName": "FAQ",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "text": {
      "type": "text"
    },
    "titleLevel": {
      "type": "enumeration",
      "default": "h2",
      "enum": [
        "h2",
        "h3"
      ]
    },
    "showAll": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "faqCategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq-category.faq-category",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "showAll"
            },
            false
          ]
        }
      }
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq.faq",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "showAll"
            },
            false
          ]
        }
      }
    }
  }
}
