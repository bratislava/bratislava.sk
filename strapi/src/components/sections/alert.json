{
  "collectionName": "components_sections_alerts",
  "info": {
    "displayName": "Upozornenie"
  },
  "options": {},
  "attributes": {
    "alertTitle": {
      "type": "string"
    },
    "alertText": {
      "type": "text",
      "required": true
    },
    "alertVariant": {
      "type": "enumeration",
      "required": true,
      "default": "warning",
      "enum": [
        "warning",
        "info",
        "success",
        "error"
      ]
    },
    "alertLinks": {
      "type": "component",
      "component": "blocks.common-link",
      "repeatable": true,
      "max": 2
    }
  },
  "config": {}
}
